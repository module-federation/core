{
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": false,
    "target": "es6",
    "module": "esnext",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "declaration": true,
    "allowJs": true,
    "lib": ["ES2021", "DOM"],
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "__tests__"]
}
