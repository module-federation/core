{
  "name": "metro-cache",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/metro-cache/src",
  "projectType": "library",
  "tags": ["type:pkg"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "echo 'No build needed for metro-cache - React Native native module'",
            "forwardAllArgs": false
          }
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "pnpm exec jest --passWithNoTests --watchman=false",
        "cwd": "packages/metro-cache",
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
