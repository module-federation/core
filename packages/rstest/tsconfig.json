{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2022",
    "target": "es2022",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "types": ["@rstest/core/globals", "node"]
  },
  "include": ["src", "rstest.config.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
