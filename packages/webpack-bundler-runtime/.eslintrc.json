{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*", "dist/**/*", "**/*.d.ts"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.json"],
      "parser": "jsonc-eslint-parser",
      "rules": {}
    },
    {
      "files": ["src/initContainerEntry.ts", "src/initializeSharing.ts"],
      "rules": {
        "no-var": "off"
      }
    },
    {
      "files": ["__tests__/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-require-imports": "off"
      }
    }
  ]
}
