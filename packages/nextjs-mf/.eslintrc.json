{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*", "dist/**/*", "**/*.d.ts"],
  "env": {
    "jest": true
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@typescript-eslint/no-unused-vars": "warn",
        "@typescript-eslint/ban-ts-comment": "warn",
        "@typescript-eslint/no-var-requires": 0,
        "@typescript-eslint/no-require-imports": "off"
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"]
    }
  ]
}
